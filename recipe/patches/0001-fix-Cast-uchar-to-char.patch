From 0277f19c3104a987b490542f281a4d3ebef2bb9e Mon Sep 17 00:00:00 2001
From: "Christopher J. Markiewicz" <markiewicz@stanford.edu>
Date: Fri, 23 May 2025 09:18:12 -0400
Subject: [PATCH] fix: Cast uchar* to char*

Borrowed from https://gitweb.gentoo.org/repo/gentoo.git/tree/media-libs/ftgl/files/ftgl-2.1.3_rc5-freetype-2.13.3.patch?id=b9c3d958486a08d3b1dd7b7c2c645a81d123f947
---
 src/FtglFont/FTVectoriser.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/FtglFont/FTVectoriser.cpp b/src/FtglFont/FTVectoriser.cpp
index 4ab3adffd..e7fb917ad 100644
--- a/src/FtglFont/FTVectoriser.cpp
+++ b/src/FtglFont/FTVectoriser.cpp
@@ -174,7 +174,7 @@ void FTVectoriser::ProcessContours()
     for(int i = 0; i < ftContourCount; ++i)
     {
         FT_Vector* pointList = &outline.points[startIndex];
-        char* tagList = &outline.tags[startIndex];
+        char* tagList = reinterpret_cast<char*>(&outline.tags[startIndex]);
 
         endIndex = outline.contours[i];
         contourLength =  (endIndex - startIndex) + 1;
-- 
